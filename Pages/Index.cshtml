@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero styles moved to wwwroot/css/site.css -->

<partial name="_Hero" model='@(new { Title = "EcoTechStore", Subtitle = "Produtos sustentáveis e tecnologia para um futuro mais verde.", PrimaryText = "Ver Produtos", PrimaryPage = "/Products", SecondaryText = "Ver Carrinho", SecondaryPage = "/Cart", Theme = "home" })' />

<div class="row">
    <div class="col-md-8">
        <h2>Destaques</h2>
        <div class="card card-eco p-3 mb-3">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#2e7d32" class="bi bi-tree" viewBox="0 0 16 16">
                        <path d="M8 0a3 3 0 0 0-2.995 2.824L5 3v1.09A5.002 5.002 0 0 0 3 9.917V11H2.5a.5.5 0 0 0 0 1H6v2.5a.5.5 0 0 0 1 0V12h2v2.5a.5.5 0 0 0 1 0V12h3.5a.5.5 0 0 0 0-1H13v-1.083A5.002 5.002 0 0 0 11 4.09V3a3 3 0 0 0-3-3z"/>
                    </svg>
                </div>
                <div class="col">
                    <h5 class="mb-1">Novos lançamentos ecológicos</h5>
                    <p class="mb-0 small">Confira produtos que aliam tecnologia e baixo impacto ambiental.</p>
                </div>
            </div>
        </div>
        <p>Explore nossa seleção com curadoria especial para quem ama a natureza.</p>
    </div>
</div>

