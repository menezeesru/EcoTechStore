@model dynamic
<div class="p-5 mb-4 hero rounded-3 text-center theme-@Model.Theme">
    @if ((Model?.Theme ?? "home") == "home") {
        <span class="floating-leaf leaf1">🌿</span>
        <span class="floating-leaf leaf2">🍃</span>
        <span class="floating-leaf leaf3">🍂</span>
    } else if ((Model?.Theme ?? "") == "products") {
        <div style="position:absolute; right:6%; top:6%; opacity:0.12; transform:rotate(12deg);">
            <!-- decorative tech SVG -->
            <svg width="96" height="96" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="4" width="20" height="12" rx="2" fill="#ffffff"/>
                <rect x="6" y="8" width="12" height="6" rx="1" fill="#c8e6c9"/>
            </svg>
        </div>
    } else if ((Model?.Theme ?? "") == "cart") {
        <span class="floating-leaf leaf1" style="font-size:34px; left:12%; top:8%;">🛍️</span>
        <span class="floating-leaf leaf2" style="right:10%; top:18%; font-size:24px;">💳</span>
    }
    <div class="container py-5">
        <h1 class="display-5 fw-bold">@Model.Title</h1>
        <p class="col-md-8 fs-4 mx-auto lead">@Model.Subtitle</p>
        <p>
            <a class="btn btn-eco btn-lg me-2" asp-page="@(Model.PrimaryPage)">@Model.PrimaryText</a>
            <a class="btn btn-outline-light btn-lg" asp-page="@(Model.SecondaryPage)">@Model.SecondaryText</a>
        </p>

        @if ((Model?.Theme ?? "") == "home") {
            <div class="mt-4 d-flex justify-content-center gap-3">
                <div class="text-center">
                    <div class="feature-icon mx-auto mb-2">🌱</div>
                    <div class="small">Sustentabilidade</div>
                </div>
                <div class="text-center">
                    <div class="feature-icon mx-auto mb-2">🔋</div>
                    <div class="small">Eficiência</div>
                </div>
                <div class="text-center">
                    <div class="feature-icon mx-auto mb-2">♻️</div>
                    <div class="small">Reciclável</div>
                </div>
            </div>
        } else if ((Model?.Theme ?? "") == "products") {
            <div class="mt-3">
                <small class="text-light">Produtos selecionados com foco em economia circular e tecnologia limpa.</small>
            </div>
        } else if ((Model?.Theme ?? "") == "cart") {
            <div class="mt-3">
                <small class="text-light">Resumo do seu pedido e opções de pagamento seguras.</small>
            </div>
        }
    </div>
</div>
