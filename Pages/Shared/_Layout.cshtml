<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoTechStore</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="shortcut icon" href="~/images/computer.svg" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoTechStore.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-page="/Index">
                    <img src="~/images/computer.svg" alt="EcoTechStore" style="height:32px; width:auto;" />
                    <span class="ms-2 align-middle d-none d-sm-inline">EcoTechStore</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Products">Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/About">Quem Somos</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Admin/Products">Admin</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item cart-icon-container">
                            <a class="nav-link cart-icon-link" asp-area="" asp-page="/Cart" title="Ir para o carrinho">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                                    <circle cx="9" cy="21" r="1"></circle>
                                    <circle cx="20" cy="21" r="1"></circle>
                                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                                </svg>
                                <span class="cart-count" id="cartCount">0</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-modern">
        <div class="footer-content">
            <div class="container">
                <div class="row footer-sections">
                    <!-- Sobre -->
                    <div class="col-md-6 mb-3 mb-md-0">
                        <div class="footer-box">
                            <h5 class="footer-title">EcoTechStore</h5>
                            <p class="footer-description">Transformando a forma como você consome tecnologia. Produtos sustentáveis e inovadores para um mundo melhor.</p>
                        </div>
                    </div>

                    <!-- Informações -->
                    <div class="col-md-6">
                        <div class="footer-box">
                            <h5 class="footer-title">Informações</h5>
                            <div class="footer-info">
                                <div class="info-item">
                                    <span class="info-icon">📧</span>
                                    <p>contato@ecotechstore.com</p>
                                </div>
                                <div class="info-item">
                                    <span class="info-icon">📱</span>
                                    <p>(11) 9999-9999</p>
                                </div>
                                <div class="info-item">
                                    <span class="info-icon">📍</span>
                                    <p>São Paulo, SP</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="footer-bottom">
                    <p class="footer-copyright">© 2026 EcoTechStore. Todos os direitos reservados.</p>
                </div>
            </div>
        </div>
        <div class="footer-wave">
            <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.87,168.19-17.28,250.45-.39C823.78,31,906.4,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#0b6623" opacity="0.3"></path>
            </svg>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
