@page "{id?}"
@model EcoTechStore.Pages.Admin.ProductFormModel
@{
    ViewData["Title"] = Model.IsEdit ? "Editar Produto" : "Novo Produto";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div style="margin-bottom: 30px;">
                <h1 style="color: #2e7d32; font-weight: 700;">@ViewData["Title"]</h1>
                <p style="color: #999; margin: 5px 0 0 0;">@(Model.IsEdit ? "Atualize as informações do produto" : "Adicione um novo produto ao catálogo")</p>
            </div>

            <div class="card shadow-sm" style="border: none; border-radius: 12px; overflow: hidden;">
                <div class="card-body p-5">
                    <form method="post">
                        <input type="hidden" asp-for="Product.Id" />

                        <div class="mb-4">
                            <label asp-for="Product.Title" class="form-label" style="color: #2e7d32; font-weight: 600;">Título do Produto</label>
                            <input asp-for="Product.Title" class="form-control form-control-lg" style="border: 2px solid #e0e0e0; border-radius: 8px;" required />
                            <span asp-validation-for="Product.Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Product.Description" class="form-label" style="color: #2e7d32; font-weight: 600;">Descrição Curta</label>
                            <textarea asp-for="Product.Description" class="form-control" rows="2" style="border: 2px solid #e0e0e0; border-radius: 8px; resize: vertical;" required placeholder="Descrição resumida do produto"></textarea>
                            <span asp-validation-for="Product.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Product.LongDescription" class="form-label" style="color: #2e7d32; font-weight: 600;">Descrição Completa</label>
                            <textarea asp-for="Product.LongDescription" class="form-control" rows="3" style="border: 2px solid #e0e0e0; border-radius: 8px; resize: vertical;" placeholder="Descrição detalhada e completa do produto"></textarea>
                            <span asp-validation-for="Product.LongDescription" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Product.Specifications" class="form-label" style="color: #2e7d32; font-weight: 600;">Especificações Técnicas</label>
                            <textarea asp-for="Product.Specifications" class="form-control" rows="3" style="border: 2px solid #e0e0e0; border-radius: 8px; resize: vertical;" placeholder="Especificações técnicas (separe com quebra de linha)&#10;Ex: Processador: Intel i7&#10;Memória: 16GB"></textarea>
                            <span asp-validation-for="Product.Specifications" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Product.Highlights" class="form-label" style="color: #2e7d32; font-weight: 600;">Diferenciais/Destaques</label>
                            <textarea asp-for="Product.Highlights" class="form-control" rows="3" style="border: 2px solid #e0e0e0; border-radius: 8px; resize: vertical;" placeholder="Diferenciais do produto (um por linha)&#10;Ex: ✓ Design moderno&#10;✓ Baixo custo"></textarea>
                            <span asp-validation-for="Product.Highlights" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Product.Price" class="form-label" style="color: #2e7d32; font-weight: 600;">Preço (R$)</label>
                                <input asp-for="Product.Price" type="number" step="0.01" class="form-control form-control-lg" style="border: 2px solid #e0e0e0; border-radius: 8px;" required />
                                <span asp-validation-for="Product.Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Product.Category" class="form-label" style="color: #2e7d32; font-weight: 600;">Categoria</label>
                                <input asp-for="Product.Category" class="form-control form-control-lg" style="border: 2px solid #e0e0e0; border-radius: 8px;" required />
                                <span asp-validation-for="Product.Category" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Product.ImageUrl" class="form-label" style="color: #2e7d32; font-weight: 600;">URL da Imagem</label>
                            <input asp-for="Product.ImageUrl" class="form-control form-control-lg" style="border: 2px solid #e0e0e0; border-radius: 8px;" required />
                            <span asp-validation-for="Product.ImageUrl" class="text-danger small"></span>
                            @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                            {
                                <div style="margin-top: 15px; padding: 15px; background-color: #f5f5f5; border-radius: 8px;">
                                    <p style="color: #999; font-size: 0.85rem; margin-bottom: 10px;"><strong>Pré-visualização:</strong></p>
                                    <img src="@Model.Product.ImageUrl" alt="Preview" style="max-width: 200px; max-height: 200px; object-fit: cover; border-radius: 8px;">
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-3" style="margin-top: 30px;">
                            <button type="submit" class="btn btn-lg" style="background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%); color: white; border: none; font-weight: 600; border-radius: 8px; flex: 1;">
                                💾 Salvar Produto
                            </button>
                            <a asp-page="Products" class="btn btn-lg btn-outline-secondary" style="border-radius: 8px; font-weight: 600; flex: 1; border: 2px solid #ddd;">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #2e7d32 !important;
        box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25) !important;
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(46, 125, 50, 0.2);
        transition: all 0.3s ease;
    }
</style>
