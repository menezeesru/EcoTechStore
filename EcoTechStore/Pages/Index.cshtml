@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}


<partial name="_Hero" model='@(new { Title = "EcoTechStore", Subtitle = "Produtos sustentáveis e tecnologia para um futuro mais verde.", PrimaryText = "Ver Produtos", PrimaryPage = "/Products", SecondaryText = "Ver Carrinho", SecondaryPage = "/Cart", Theme = "home" })' />

<!-- Produto destacado bb -->
<div class="container my-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <img src="~/images/notebook-x15.jpeg" alt="Notebook EcoGreen X15 Pro" class="img-fluid rounded" style="max-height: 500px; object-fit: cover; width: 100%;">
        </div>
        <div class="col-lg-6">
            <span class="badge bg-success mb-3">Novo Lançamento</span>
            <h2 class="mb-2" style="color: #2e7d32; font-weight: bold;">
                EcoGreen X15 <span style="color: #7cb342;">PRO</span>
            </h2>
            <p class="text-muted mb-4">Notebook de alta performance com sustentabilidade</p>

            <div class="mb-4">
                <h5 class="mb-3" style="color: #2e7d32;">Destaques do Produto</h5>
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <strong>🔧 Processador:</strong> AMD Ryzen 7 (até 4.7GHz)
                    </li>
                    <li class="mb-2">
                        <strong>💾 Memória:</strong> 16GB DDR5 (expansível)
                    </li>
                    <li class="mb-2">
                        <strong>⚡ Armazenamento:</strong> SSD NVMe 512GB
                    </li>
                    <li class="mb-2">
                        <strong>🖥️ Tela:</strong> 15,6" Full HD (1920x1080) IPS
                    </li>
                    <li class="mb-2">
                        <strong>📡 Conectividade:</strong> Wi-Fi 6 + Bluetooth 5.2
                    </li>
                    <li class="mb-2">
                        <strong>🌱 Eco-friendly:</strong> Materiais reciclados e baixo consumo
                    </li>
                </ul>
            </div>

            <div class="mb-4">
                <p>
                    <strong style="font-size: 28px; color: #2e7d32;">
                        @Model.FeaturedProduct?.Price.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))
                    </strong>
                </p>
            </div>

            <div class="d-grid gap-2">
                <a asp-page="/Product" asp-route-id="1" class="btn btn-success btn-lg">
                    Ver Detalhes
                </a>
                <form method="post" asp-page-handler="Add" style="margin: 0;">
                    <input type="hidden" name="productId" value="1" />
                    <input type="hidden" name="quantity" value="1" />
                    <button type="submit" class="btn btn-outline-success btn-lg w-100">
                        Adicionar ao Carrinho
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>


