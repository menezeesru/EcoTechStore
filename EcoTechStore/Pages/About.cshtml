@page
@model AboutModel
@{
    ViewData["Title"] = "Sobre Nós";
}

<!-- Hero Section -->
<partial name="_Hero" model='@(new { Title = "Sobre EcoTechStore", Subtitle = "Conectando sustentabilidade, inovação e tecnologia para transformar o mundo", PrimaryText = "Ver Nossa Missão", PrimaryPage = "#mission", SecondaryText = "Entrar em Contato", SecondaryPage = "#contact", Theme = "about" })' />

<!-- Mission Section -->
<section id="mission" class="py-5 bg-light" style="position: relative; overflow: hidden;">
    <!-- Decorative animated background -->
    <div style="position: absolute; top: 50%; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(102, 187, 106, 0.15) 0%, transparent 70%); border-radius: 50%; animation: float 6s ease-in-out infinite; z-index: 0;"></div>
    <div style="position: absolute; bottom: -50px; left: -50px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(67, 160, 71, 0.1) 0%, transparent 70%); border-radius: 50%; animation: pulse-bg 4s ease-in-out infinite; z-index: 0;"></div>

    <div class="container" style="position: relative; z-index: 1;">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="position-relative animation-scale-in">
                    <img src="~/images/mission-illustration.svg" alt="Nossa Missão" class="img-fluid rounded-4" style="max-height: 450px; object-fit: cover; width: 100%; box-shadow: 0 15px 45px rgba(0,0,0,0.1); animation: slideInLeft 0.8s ease-out;">
                    <div class="position-absolute" style="bottom: -20px; right: -20px; width: 200px; height: 200px; background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); border-radius: 20px; opacity: 0.15; z-index: -1; animation: rotateSlow 10s linear infinite;"></div>
                </div>
            </div>
            <div class="col-lg-6" style="animation: slideInRight 0.8s ease-out;">
                <h2 class="mb-4" style="color: #2e7d32; font-weight: 700; font-size: 2.5rem; position: relative; display: inline-block;">
                    <span style="background: linear-gradient(135deg, #2e7d32, #43a047); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Nossa Missão</span>
                    <div style="position: absolute; bottom: -10px; left: 0; height: 3px; width: 100%; background: linear-gradient(90deg, #43a047, #66bb6a, transparent); animation: slideRight 0.8s ease-out 0.2s both;"></div>
                </h2>
                <p class="lead mb-3" style="color: #333; line-height: 1.8; animation: fadeIn 0.8s ease-out 0.3s both;">
                    Na <strong>EcoTechStore</strong>, acreditamos que a tecnologia deve servir ao planeta, não prejudicá-lo. Nossa missão é revolucionar o mercado de eletrônicos oferecendo produtos de alta performance que não comprometem o futuro das gerações vindouras.
                </p>
                <p class="text-muted mb-4" style="line-height: 1.8; animation: fadeIn 0.8s ease-out 0.4s both;">
                    Cada produto que selecionamos é cuidadosamente escolhido por sua eficiência energética, materiais sustentáveis e impacto ambiental reduzido. Queremos provar que inovação e responsabilidade ambiental não apenas podem coexistir – devem andar de mãos dadas.
                </p>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="d-flex align-items-start icon-card-hover" style="animation: fadeIn 0.8s ease-out 0.5s both;">
                            <span style="font-size: 28px; color: #43a047; margin-right: 15px; animation: bounce 2s ease-in-out infinite;">🌍</span>
                            <div>
                                <h5 style="color: #2e7d32; font-weight: 600;">Sustentabilidade</h5>
                                <p class="mb-0 small text-muted">Reduzir emissão de carbono</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="d-flex align-items-start icon-card-hover" style="animation: fadeIn 0.8s ease-out 0.6s both;">
                            <span style="font-size: 28px; color: #43a047; margin-right: 15px; animation: pulse 2s ease-in-out infinite;">⚡</span>
                            <div>
                                <h5 style="color: #2e7d32; font-weight: 600;">Performance</h5>
                                <p class="mb-0 small text-muted">Tecnologia de ponta</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Vision & Values Section -->
<section class="py-5" style="background: linear-gradient(135deg, #ffffff 0%, #f9fdf7 100%); position: relative; overflow: hidden;">
    <div class="container">
        <h2 class="text-center mb-5" style="color: #2e7d32; font-weight: 700; font-size: 2.5rem; animation: slideDown 0.6s ease-out;">
            Nossa Visão e Valores
            <div style="height: 4px; width: 100px; background: linear-gradient(90deg, #43a047, #66bb6a, #9ccc65); border-radius: 2px; margin: 15px auto 0;"></div>
        </h2>

        <div class="row g-4">
            <!-- Card 1: Visão -->
            <div class="col-lg-4" style="animation: scaleInCard 0.6s ease-out 0.1s both;">
                <div class="vision-card card card-eco h-100 border-0" style="background: linear-gradient(135deg, rgba(67, 160, 71, 0.05) 0%, rgba(102, 187, 106, 0.05) 100%); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); position: relative; overflow: hidden;">
                    <div style="position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s;"></div>
                    <div class="card-body p-4" style="position: relative; z-index: 1;">
                        <div class="mb-3" style="font-size: 48px; animation: float 3s ease-in-out infinite;">🔭</div>
                        <h5 class="card-title" style="color: #2e7d32; font-weight: 700;">Visão Global</h5>
                        <p class="card-text text-muted mb-0">
                            Transformar a indústria de tecnologia em um modelo sustentável, onde cada compra contribui positivamente para o meio ambiente e a sociedade.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Card 2: Inovação -->
            <div class="col-lg-4" style="animation: scaleInCard 0.6s ease-out 0.2s both;">
                <div class="vision-card card card-eco h-100 border-0" style="background: linear-gradient(135deg, rgba(67, 160, 71, 0.05) 0%, rgba(102, 187, 106, 0.05) 100%); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); position: relative; overflow: hidden;">
                    <div style="position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s;"></div>
                    <div class="card-body p-4" style="position: relative; z-index: 1;">
                        <div class="mb-3" style="font-size: 48px; animation: float 3s ease-in-out 0.2s infinite;">💡</div>
                        <h5 class="card-title" style="color: #2e7d32; font-weight: 700;">Inovação Contínua</h5>
                        <p class="card-text text-muted mb-0">
                            Investimos constantemente em pesquisa para encontrar novas formas de reduzir impacto ambiental sem comprometer qualidade e performance.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Card 3: Comunidade -->
            <div class="col-lg-4" style="animation: scaleInCard 0.6s ease-out 0.3s both;">
                <div class="vision-card card card-eco h-100 border-0" style="background: linear-gradient(135deg, rgba(67, 160, 71, 0.05) 0%, rgba(102, 187, 106, 0.05) 100%); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); position: relative; overflow: hidden;">
                    <div style="position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s;"></div>
                    <div class="card-body p-4" style="position: relative; z-index: 1;">
                        <div class="mb-3" style="font-size: 48px; animation: float 3s ease-in-out 0.4s infinite;">🤝</div>
                        <h5 class="card-title" style="color: #2e7d32; font-weight: 700;">Comunidade</h5>
                        <p class="card-text text-muted mb-0">
                            Acreditamos no poder da comunidade. Seus feedbacks e sugestões moldam continuamente nossos produtos e serviços.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Core Values -->
        <div class="row mt-5 g-3">
            <div class="col-md-6" style="animation: slideInLeft 0.7s ease-out 0.4s both;">
                <div class="values-card p-4 rounded-3" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; transition: all 0.4s ease; cursor: pointer; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50%; right: -50%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                    <h5 class="mb-3 fw-bold" style="position: relative; z-index: 1;">🌱 Responsabilidade Ambiental</h5>
                    <p class="mb-0" style="position: relative; z-index: 1;">Cada decisão é tomada considerando o impacto no planeta. Usamos materiais reciclados, minimizamos desperdícios e compensamos nossa pegada de carbono.</p>
                </div>
            </div>
            <div class="col-md-6" style="animation: slideInRight 0.7s ease-out 0.4s both;">
                <div class="values-card p-4 rounded-3" style="background: linear-gradient(135deg, #7cb342 0%, #9ccc65 100%); color: white; transition: all 0.4s ease; cursor: pointer; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50%; right: -50%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                    <h5 class="mb-3 fw-bold" style="position: relative; z-index: 1;">🔒 Transparência Total</h5>
                    <p class="mb-0" style="position: relative; z-index: 1;">Somos honestos sobre nossas práticas, desafios e progressos. Você merece saber exatamente de onde vem cada produto.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why We're Different Section -->
<section class="py-5 bg-light" style="position: relative; overflow: hidden;">
    <!-- Animated background -->
    <div style="position: absolute; top: 10%; right: -100px; width: 350px; height: 350px; background: radial-gradient(circle, rgba(67, 160, 71, 0.08) 0%, transparent 70%); border-radius: 50%; animation: float 8s ease-in-out infinite; z-index: 0;"></div>

    <div class="container" style="position: relative; z-index: 1;">
        <h2 class="text-center mb-5" style="color: #2e7d32; font-weight: 700; font-size: 2.3rem; animation: slideDown 0.6s ease-out;">
            Por Que Somos Diferentes
            <div style="height: 4px; width: 100px; background: linear-gradient(90deg, #43a047, #66bb6a, #9ccc65); border-radius: 2px; margin: 15px auto 0;"></div>
        </h2>

        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4" style="animation: scaleInCard 0.6s ease-out 0.1s both;">
                <div class="difference-card text-center" style="padding: 30px 20px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer;">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.2); animation: float 3s ease-in-out infinite;">
                        <span style="font-size: 48px;">🔋</span>
                    </div>
                    <h5 style="color: #2e7d32; font-weight: 700;">Eficiência Máxima</h5>
                    <p class="text-muted">Todos os produtos têm eficiência energética certificada, reduzindo custos e impacto ambiental.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4" style="animation: scaleInCard 0.6s ease-out 0.2s both;">
                <div class="difference-card text-center" style="padding: 30px 20px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer;">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.2); animation: float 3s ease-in-out 0.2s infinite;">
                        <span style="font-size: 48px;">♻️</span>
                    </div>
                    <h5 style="color: #2e7d32; font-weight: 700;">100% Reciclável</h5>
                    <p class="text-muted">Embalagens biodegradáveis e programas de reciclagem para produtos antigos.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4" style="animation: scaleInCard 0.6s ease-out 0.3s both;">
                <div class="difference-card text-center" style="padding: 30px 20px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer;">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.2); animation: float 3s ease-in-out 0.4s infinite;">
                        <span style="font-size: 48px;">🌐</span>
                    </div>
                    <h5 style="color: #2e7d32; font-weight: 700;">Certificações Globais</h5>
                    <p class="text-muted">Todos os produtos atendem aos mais altos padrões internacionais de sustentabilidade.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4" style="animation: scaleInCard 0.6s ease-out 0.4s both;">
                <div class="difference-card text-center" style="padding: 30px 20px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer;">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.2); animation: float 3s ease-in-out 0.6s infinite;">
                        <span style="font-size: 48px;">💚</span>
                    </div>
                    <h5 style="color: #2e7d32; font-weight: 700;">Impacto Social</h5>
                    <p class="text-muted">1% de cada venda vai para projetos de reflorestamento e educação ambiental.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Journey Section -->
<section class="py-5" style="background: linear-gradient(135deg, #ffffff 0%, #f9fdf7 100%); position: relative;">
    <div class="container">
        <h2 class="text-center mb-5" style="color: #2e7d32; font-weight: 700; font-size: 2.3rem; animation: slideDown 0.6s ease-out;">
            Nossa Jornada
            <div style="height: 4px; width: 100px; background: linear-gradient(90deg, #43a047, #66bb6a, #9ccc65); border-radius: 2px; margin: 15px auto 0;"></div>
        </h2>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                
                <div style="position: relative; padding: 20px 0;">
                    <!-- Linha central-->
                    <div style="position: absolute; left: 50%; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, #43a047 0%, #66bb6a 50%, #9ccc65 100%); animation: slideDown 0.8s ease-out; z-index: 0;"></div>

                    <!-- item 1 -->
                    <div class="row mb-5" style="position: relative; z-index: 1; animation: fadeIn 0.6s ease-out 0.1s both;">
                        <div class="col-md-6">
                            <div class="p-4 rounded-3 bg-light" style="box-shadow: 0 8px 25px rgba(67, 160, 71, 0.1); transition: all 0.3s ease;">
                                <h5 style="color: #2e7d32; font-weight: 700;">🌱 2023 - O Início</h5>
                                <p class="text-muted mb-0">Fundação da EcoTechStore com uma simples ideia: provar que sustentabilidade e performance podem andar juntas.</p>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #43a047, #66bb6a); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin: auto; box-shadow: 0 10px 25px rgba(67, 160, 71, 0.3); font-size: 20px; animation: pulse-ring 2s ease-in-out infinite;">
                                2023
                            </div>
                        </div>
                    </div>

                    <!-- item 2 -->
                    <div class="row mb-5" style="position: relative; z-index: 1; animation: fadeIn 0.6s ease-out 0.2s both;">
                        <div class="col-md-6 order-md-2">
                            <div class="p-4 rounded-3 bg-light" style="box-shadow: 0 8px 25px rgba(67, 160, 71, 0.1); transition: all 0.3s ease;">
                                <h5 style="color: #2e7d32; font-weight: 700;">📈 2024 - Crescimento</h5>
                                <p class="text-muted mb-0">Atingimos 10.000 clientes satisfeitos e expandimos nosso catálogo com novas categorias de produtos.</p>
                            </div>
                        </div>
                        <div class="col-md-6 order-md-1 d-flex align-items-center">
                            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #66bb6a, #7cb342); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin: auto; box-shadow: 0 10px 25px rgba(102, 187, 106, 0.3); font-size: 20px; animation: pulse-ring 2s ease-in-out infinite;">
                                2024
                            </div>
                        </div>
                    </div>

                    <!-- Tome o item 3 -->
                    <div class="row mb-5" style="position: relative; z-index: 1; animation: fadeIn 0.6s ease-out 0.3s both;">
                        <div class="col-md-6">
                            <div class="p-4 rounded-3 bg-light" style="box-shadow: 0 8px 25px rgba(67, 160, 71, 0.1); transition: all 0.3s ease;">
                                <h5 style="color: #2e7d32; font-weight: 700;">🏆 2025 - Reconhecimento</h5>
                                <p class="text-muted mb-0">Recebemos certificação B Corp e prêmios por inovação em sustentabilidade no setor de tecnologia.</p>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #7cb342, #9ccc65); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin: auto; box-shadow: 0 10px 25px rgba(124, 179, 66, 0.3); font-size: 20px; animation: pulse-ring 2s ease-in-out infinite;">
                                2025
                            </div>
                        </div>
                    </div>

                    <!-- Vamo o item 4 -->
                    <div class="row" style="position: relative; z-index: 1; animation: fadeIn 0.6s ease-out 0.4s both;">
                        <div class="col-md-6 order-md-2">
                            <div class="p-4 rounded-3 bg-light" style="box-shadow: 0 8px 25px rgba(67, 160, 71, 0.1); transition: all 0.3s ease;">
                                <h5 style="color: #2e7d32; font-weight: 700;">🚀 2026 - Presente</h5>
                                <p class="text-muted mb-0">Operando em 15 países, plantamos 100.000 árvores e continuamos revolucionando o mercado tech.</p>
                            </div>
                        </div>
                        <div class="col-md-6 order-md-1 d-flex align-items-center">
                            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #9ccc65, #43a047); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin: auto; box-shadow: 0 10px 25px rgba(67, 160, 71, 0.3); font-size: 20px; animation: pulse-ring 2s ease-in-out infinite;">
                                2026
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Impact Section -->
<section class="py-5 bg-light" style="position: relative; overflow: hidden;">
    <!-- Animated background -->
    <div style="position: absolute; bottom: -50px; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(102, 187, 106, 0.1) 0%, transparent 70%); border-radius: 50%; animation: float 7s ease-in-out infinite; z-index: 0;"></div>

    <div class="container" style="position: relative; z-index: 1;">
        <h2 class="text-center mb-5" style="color: #2e7d32; font-weight: 700; font-size: 2.3rem; animation: slideDown 0.6s ease-out;">
            Nosso Impacto
            <div style="height: 4px; width: 100px; background: linear-gradient(90deg, #43a047, #66bb6a, #9ccc65); border-radius: 2px; margin: 15px auto 0;"></div>
        </h2>

        <div class="row text-center">
            <div class="col-md-3 mb-4" style="animation: scaleInCard 0.6s ease-out 0.1s both;">
                <div class="impact-card p-4" style="background: white; border-radius: 15px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.1); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50%; right: -50%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(67, 160, 71, 0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                    <div style="position: relative; z-index: 1;">
                        <h3 style="color: #43a047; font-weight: 700; font-size: 2.8rem; animation: countUp 2s ease-out 0.5s both;">50K</h3>
                        <span style="color: #43a047; font-size: 1.2rem;">+</span>
                        <p style="color: #2e7d32; font-weight: 600; margin-bottom: 8px;">Clientes Satisfeitos</p>
                        <p class="text-muted small">Em todo o mundo confiando em nossos produtos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4" style="animation: scaleInCard 0.6s ease-out 0.2s both;">
                <div class="impact-card p-4" style="background: white; border-radius: 15px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.1); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50%; right: -50%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(67, 160, 71, 0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                    <div style="position: relative; z-index: 1;">
                        <h3 style="color: #43a047; font-weight: 700; font-size: 2.8rem; animation: countUp 2s ease-out 0.5s both;">100K</h3>
                        <p style="color: #2e7d32; font-weight: 600; margin-bottom: 8px;">Árvores Plantadas</p>
                        <p class="text-muted small">Através de nosso programa de reflorestamento</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4" style="animation: scaleInCard 0.6s ease-out 0.3s both;">
                <div class="impact-card p-4" style="background: white; border-radius: 15px; box-shadow: 0 10px 30px rgba(67, 160, 71, 0.1); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); cursor: pointer; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50%; right: -50%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(67, 160, 71, 0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                    <div style="position: relative; z-index: 1;">
                        <h3 style="color: #43a047; font-weight: 700; font-size: 2.8rem; animation: countUp 2s ease-out 0.5s both;">500T</h3>
                        <p style="color: #2e7d32; font-weight: 600; margin-bottom: 8px;">Emissões Evitadas</p>
                        <p class="text-muted small">Redução de carbono em comparação com marcas convencionais</p>
                    </div>
