<style>
    .card-eco {
        transition: all 0.3s ease;
    }

    .card-eco:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(67, 160, 71, 0.15) !important;
    }

    section {
        scroll-behavior: smooth;
    }

    /* ============ ANIMAÇÕES PRINCIPAIS ============ */

    /* Flutuação suave */
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }

    /* Entrada deslizando da esquerda */
    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Entrada deslizando da direita */
    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Deslizar da direita para esquerda */
    @@keyframes slideRight {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
    }

    /* Deslizar para baixo */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Fade in suave */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    /* Escala com entrada */
    @@keyframes scaleInCard {
        from {
            opacity: 0;
            transform: scale(0.9);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Rotação lenta */
    @@keyframes rotateSlow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Bounce - pulo */
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    /* Pulse para fundo */
    @@keyframes pulse-bg {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.8; }
    }

    /* Pulse ring - anel pulsante */
    @@keyframes pulse-ring {
        0%, 100% {
            box-shadow: 0 10px 25px rgba(67, 160, 71, 0.3);
        }
        50% {
            box-shadow: 0 10px 40px rgba(67, 160, 71, 0.6);
        }
    }

    /* Count up - contagem */
    @@keyframes countUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ============ CLASSES COM HOVER ============ */

    /* Cartão de visão com hover efeito */
    .vision-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 50px rgba(67, 160, 71, 0.2) !important;
    }

    .vision-card:hover::before {
        left: 100%;
    }

    /* Cartão de diferença com hover */
    .difference-card:hover {
        transform: translateY(-15px) scale(1.05);
        background: linear-gradient(135deg, rgba(67, 160, 71, 0.05) 0%, rgba(102, 187, 106, 0.05) 100%);
        border-radius: 20px;
        box-shadow: 0 20px 50px rgba(67, 160, 71, 0.15) !important;
    }

    /* Cartão de impacto com hover */
    .impact-card:hover {
        transform: translateY(-12px) scale(1.02);
        box-shadow: 0 25px 50px rgba(67, 160, 71, 0.2) !important;
    }

    /* Ícone card com hover */
    .icon-card-hover:hover {
        transform: translateX(5px);
    }

    /* ============ VALORES CARD COM HOVER ============ */
    .values-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 50px rgba(67, 160, 71, 0.3) !important;
    }

    .values-card:hover::before {
        top: 50%;
        right: 50%;
    }

    /* ============ TEAM CARD ANIMAÇÕES ============ */
    .team-card {
        position: relative;
        overflow: hidden;
    }

    .team-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s ease;
    }

    .team-card:hover::before {
        left: 100%;
    }

    .team-card:hover {
        transform: translateY(-15px) scale(1.02);
        box-shadow: 0 30px 60px rgba(67, 160, 71, 0.2) !important;
    }

    .team-card:hover div[style*="font-size: 24px"] {
        animation: bounce 0.6s ease-in-out;
    }

    @@keyframes bounce-emoji {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    /* Efeito 3D no avatar */
    @@keyframes rotateBorder {
        0% { border-color: #43a047; }
        50% { border-color: #66bb6a; }
        100% { border-color: #43a047; }
    }

    .team-card:hover div[style*="border: 3px solid"] {
        animation: rotateBorder 0.8s ease infinite;
    }

    /* ============ ANIMAÇÃO SCALE IN ============ */
    .animation-scale-in {
        animation: scaleInCard 0.8s ease-out;
    }

    /* ============ RESPONSIVE IMPROVEMENTS ============ */
    @@media (max-width: 768px) {
        .vision-card, .difference-card, .impact-card {
            animation: scaleInCard 0.6s ease-out !important;
        }

        .team-card {
            animation: fadeIn 0.6s ease-out !important;
        }
    }
</style>
