@page
@model EcoTechStore.Pages.ProductsModel
@{
    ViewData["Title"] = "Produtos";
}

<partial name="_Hero" model='@(new { Title = "Produtos", Subtitle = "Explore nossa seleção de produtos sustentáveis.", PrimaryText = "Voltar para Home", PrimaryPage = "/Index", SecondaryText = "Ver Carrinho", SecondaryPage = "/Cart", Theme = "products" })' />

<div class="container">
    <div class="row">
        <!-- Sidebar: filtros e categorias -->
        <aside class="col-md-3">
            <div class="filter-section mb-4 p-4">
                <h5>Filtros</h5>
                <hr />

                <h6>Categorias</h6>
                <form method="get">
                    <div class="filter-options">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="category" value="" id="cat-all" 
                                   @(string.IsNullOrEmpty(Model.SelectedCategory) ? "checked" : "") 
                                   onchange="this.form.submit()">
                            <label class="form-check-label" for="cat-all">
                                Todas as Categorias
                            </label>
                        </div>
                        @foreach (var category in Model.Categories)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="category" value="@category" id="cat-@category"
                                       @(Model.SelectedCategory == category ? "checked" : "")
                                       onchange="this.form.submit()">
                                <label class="form-check-label" for="cat-@category">
                                    @category
                                </label>
                            </div>
                        }
                    </div>
                </form>
            </div>
        </aside>

        <!-- Lista de produtos -->
        <section class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div><strong>Mostrando @Model.Products.Count produtos</strong></div>
                <div>
                    <label class="me-2 small">Ordenar por</label>
                    <select class="form-select form-select-sm d-inline-block" style="width:auto;">
                        <option>Relevância</option>
                        <option>Preço: menor</option>
                        <option>Preço: maior</option>
                    </select>
                </div>
            </div>

            <div class="row">
                @foreach (var item in Model.Products)
                {
                    <div class="col-md-4">
                        <div class="card card-product mb-4 h-100">
                            <div class="product-image-wrapper">
                                <a asp-page="/Product" asp-route-id="@item.Id" class="product-image-link">
                                    <img src="@Url.Content(item.ImageUrl)" class="card-img-top product-image" alt="@item.Title">
                                    <div class="product-overlay">
                                        <span class="view-details-text">Ver Detalhes</span>
                                    </div>
                                </a>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title product-title mb-2">@item.Title</h5>
                                <p class="card-text product-description flex-grow-1">@item.Description</p>
                                <div class="product-price-section mb-3">
                                    <strong class="product-price">@item.Price.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</strong>
                                </div>
                                <div class="d-grid gap-2">
                                    <a asp-page="/Product" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">
                                        Ver Detalhes
                                    </a>
                                    <form method="post" asp-page-handler="Add" style="margin: 0;">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-sm btn-success w-100">Adicionar ao Carrinho</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
