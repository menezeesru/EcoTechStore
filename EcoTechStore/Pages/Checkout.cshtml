@page
@model EcoTechStore.Pages.CheckoutModel
@{
    ViewData["Title"] = "Finalizar Compra";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Finalizar Compra</h1>

            @if (!Model.Items.Any())
            {
                <div class="alert alert-info">
                    Seu carrinho está vazio. <a asp-page="/Products" class="alert-link">Volte para produtos</a>
                </div>
            }
            else
            {
                <div class="row">
                    <!-- Resumo do Pedido -->
                    <div class="col-md-6">
                        <div class="card mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">Resumo do Pedido</h5>
                            </div>
                            <div class="card-body">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                                        <div>
                                            <strong>@item.Product.Title</strong>
                                            <br />
                                            <small class="text-muted">Qtd: @item.Quantity</small>
                                        </div>
                                        <div class="text-end">
                                            @((item.Product.Price * item.Quantity).ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")))
                                        </div>
                                    </div>
                                }
                                <div class="d-flex justify-content-between mt-4">
                                    <h5>Total</h5>
                                    <h5>@Model.Total.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Forma de Pagamento -->
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0">Forma de Pagamento</h5>
                            </div>
                            <div class="card-body">
                                <form method="post" asp-page-handler="Complete">
                                    <div class="mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="paymentMethod" value="credit-card" id="payment-cc" checked>
                                            <label class="form-check-label" for="payment-cc">
                                                <strong>Cartão de Crédito</strong>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="paymentMethod" value="debit-card" id="payment-debit">
                                            <label class="form-check-label" for="payment-debit">
                                                <strong>Cartão de Débito</strong>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="paymentMethod" value="pix" id="payment-pix">
                                            <label class="form-check-label" for="payment-pix">
                                                <strong>PIX</strong>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="paymentMethod" value="boleto" id="payment-boleto">
                                            <label class="form-check-label" for="payment-boleto">
                                                <strong>Boleto Bancário</strong>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-success btn-lg">Confirmar Compra</button>
                                        <a asp-page="/Cart" class="btn btn-secondary">Voltar ao Carrinho</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
